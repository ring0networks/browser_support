{
  "manifest_version": 3,
  "name": "802.11 Networks block page extension (service worker)",
  "version": "0.3",
  "description": "Redirects connection resets to a custom block page.",
  "permissions": [
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["block_page.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
